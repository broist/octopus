{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "octopus/octopus",
    "type": "project",
    "description": "Octopus – Építőipari projektvezető és rendszerező alkalmazás.",
    "keywords": ["laravel", "construction", "project-management"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.9",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/fortify": "^1.0|^2.0",
        "laravel/framework": "^13.12",
        "league/flysystem-aws-s3-v3": "^3.0",
        "mpdf/mpdf": "^8.3",
        "sabre/dav": "^4.6",
        "spatie/laravel-permission": "^6.0|^7.0",
        "tightenco/ziggy": "^2.0",
        "webklex/php-imap": "^6.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0|^9.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
