APP_NAME=Octopus
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Budapest
APP_URL=http://localhost:8080
APP_LOCALE=hu
APP_FALLBACK_LOCALE=en

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Database (PostgreSQL) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=octopus
DB_USERNAME=octopus
DB_PASSWORD=octopus

# --- Session / Cache / Queue (Redis) ---
SESSION_DRIVER=redis
# Tétlenségi lejárat percben (120 = 2 óra), és a süti szűnjön meg a böngésző
# bezárásakor — mindkettő után újra kell jelentkezni (jelszó + MFA).
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=true
CACHE_STORE=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="octopus@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Filesystem: local server disk + S3 (hybrid) ---
FILESYSTEM_DISK=local
# Ha az AWS_ACCESS_KEY_ID ki van töltve, a tervrajz + fotó kategória és minden
# PLANS_S3_MIN_MB-nél nagyobb fájl automatikusan S3-ba kerül; egyébként minden
# a szerverre megy (storage/app/documents). A már feltöltött fájlok a helyükön
# maradnak, csak az új feltöltésekre vonatkozik.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=octopus-plans
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
PLANS_S3_MIN_MB=25

# --- Weather API (Daily Report auto weather). Open-Meteo needs no key. ---
WEATHER_PROVIDER=open-meteo
WEATHER_API_KEY=

# --- Apple / iCloud CalDAV sync (Apple ID + app-specific password) ---
CALDAV_ICLOUD_BASE_URL=https://caldav.icloud.com

# --- Számlázz.hu Számla Agent (integrated LAST) ---
SZAMLAZZHU_AGENT_KEY=
SZAMLAZZHU_API_URL=https://www.szamlazz.hu/szamla/

VITE_APP_NAME="${APP_NAME}"

# --- Webes ajánlatkérések (acuwall.hu űrlap → automatikus projekt) ---
LEADS_IMAP_HOST=
LEADS_IMAP_PORT=993
LEADS_IMAP_ENCRYPTION=ssl
LEADS_IMAP_USERNAME=acuwall@acuwall.hu
LEADS_IMAP_PASSWORD=
LEADS_IMAP_FOLDER=INBOX
LEADS_WEBHOOK_TOKEN=
